# Recommended on Windows (no compiler needed):
BOOK_LLM_BACKEND=ollama
BOOK_LLM_OLLAMA_URL=http://127.0.0.1:11434
BOOK_LLM_OLLAMA_MODEL=llama3

# If you want to use a local GGUF file directly (requires C++ build tools):
# BOOK_LLM_BACKEND=llama_cpp
# BOOK_LLM_MODEL_PATH=C:\path\to\model.gguf
# BOOK_LLM_N_CTX=4096
# BOOK_LLM_N_THREADS=0
# BOOK_LLM_N_GPU_LAYERS=0
# BOOK_LLM_CHAT_FORMAT=llama-3
